<record id="library_book_view_form" model="ir.ui.view">
    <field name="name">library.book.form</field>
    <field name="model">library.book</field>
    <field name="arch" type="xml">
        <form string="Book">
            <header>
                <button name="action_borrow" type="object" string="Borrow" class="btn-primary" invisible="state != 'available'"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,available,borrowed"/>
            </header>
            <sheet>
                <div class="oe_title">
                    <h1><field name="name" placeholder="Book Title"/></h1>
                </div>
                <group>
                    <group string="Basic Info">
                        <field name="author_ids" widget="many2many_tags"/>
                        <field name="isbn"/>
                        <field name="publisher_id"/>
                    </group>
                    <group string="Details">
                        <field name="publication_date"/>
                        <field name="pages"/>
                        <field name="price" widget="monetary"/>
                    </group>
                </group>
                <notebook>
                    <page string="Description">
                        <field name="description"/>
                    </page>
                    <page string="Borrowing History">
                        <field name="borrowing_ids"/>
                    </page>
                </notebook>
            </sheet>
            <div class="oe_chatter">
                <field name="message_follower_ids"/>
                <field name="message_ids"/>
            </div>
        </form>
    </field>
</record>